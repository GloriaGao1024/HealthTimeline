# Local server
PORT=8792

# Baidu OCR
BAIDU_OCR_API_KEY=your_baidu_ocr_api_key
BAIDU_OCR_SECRET_KEY=your_baidu_ocr_secret_key
BAIDU_OCR_ENDPOINT=https://aip.baidubce.com/rest/2.0/ocr/v1/general_basic

# AI chat. Compatible with OpenAI-style chat completion APIs.
AI_API_BASE=https://api.deepseek.com
AI_CHAT_COMPLETIONS_URL=
AI_API_KEY=your_ai_api_key
AI_MODEL=deepseek-chat
